APP_NAME=Translify
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=replace_with_a_strong_secret

# Database (RDS in production)
DATABASE_URL=mysql+pymysql://admin:password@localhost:3306/translify

# AWS
AWS_REGION=ap-south-1
AWS_S3_BUCKET=translify-files-bucket
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Local development toggle (set false on EC2)
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_DIR=./local_storage
